// Firestore Security Rules
// Paste into Firebase Console > Firestore Database > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: public read, owner-only write — EXCEPT the reward fields
    // (points/streak/claim state), which only the trusted server may write via
    // the Admin SDK. This makes points impossible to grant from the client.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny(
                         ['points', 'streak', 'lastClaimAt', 'claimCount', 'lastClaimTxHash']);
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
                         ['points', 'streak', 'lastClaimAt', 'claimCount', 'lastClaimTxHash']);
    }

    // Prediction markets: public read. A signed-in user may create a market they
    // own and edit only its descriptive fields — the YES/NO tallies, status,
    // volume and creator are server/creation-owned (the bet endpoint updates
    // tallies via Admin), so clients can't inflate or self-resolve a market.
    match /markets/{marketId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.creator == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.creator == request.auth.uid
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
                         ['yesBets', 'noBets', 'creator', 'creatorProfile', 'status', 'volumeUSD', 'metrics']);
      allow delete: if request.auth != null && resource.data.creator == request.auth.uid;
    }

    // Social feed posts
    match /feed/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['uid', 'displayName', 'handle', 'text', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500;
      allow update, delete: if request.auth != null
                             && resource.data.uid == request.auth.uid;
    }

    // Likes / reposts: one doc per user, keyed by uid
    match /feed/{postId}/likes/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /feed/{postId}/reposts/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Replies to feed posts
    match /feed/{postId}/replies/{replyId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['uid', 'text', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500;
      allow update, delete: if request.auth != null
                             && resource.data.uid == request.auth.uid;
    }

    // Market comments (userAddress holds the Firebase uid)
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userAddress;
    }

    // News items: public read; writes only via the trusted admin endpoint
    // (server-only ADMIN_PASSWORD + Admin SDK). Not client-writable, so no one
    // can inject news/phishing items directly.
    match /news/{newsId} {
      allow read: if true;
      allow write: if false;
    }

    // Public news cache: public read for instant paint; writes only via the
    // trusted /api/news-cache endpoint (Admin), which writes the server's own
    // aggregated feed — so the cache can't be poisoned with injected items.
    match /newsCache/{view} {
      allow read: if true;
      allow write: if false;
    }

    // Market predictions: public read; only the trusted server (Admin SDK, which
    // bypasses rules) may write, after verifying the on-chain bet tx.
    match /bets/{betId} {
      allow read: if true;
      allow write: if false;
    }

    // Daily leaderboard tallies: public read; server-written only.
    match /dailyPoints/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
